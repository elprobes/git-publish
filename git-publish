#!/usr/bin/env bash

set -uo pipefail

LOGFILE="$HOME/.local/state/git-publish.log"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_raw() {
    local level="$1"
    local msg="$2"

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$level] $msg" >> "$LOGFILE"
}

info() {
    echo -e "${CYAN}󰔟 $*${NC}"
}

success() {
    echo -e "${GREEN}󰄬 $*${NC}"
}

warn() {
    echo -e "${YELLOW}󰘳 $*${NC}"
}

error() {
    echo -e "${RED}󰅙 $*${NC}"
}

log_info() {
    log_raw "INFO" "$*"
    info "$*"
}

log_success() {
    log_raw "OK" "$*"
    success "$*"
}

log_warn() {
    log_raw "WARN" "$*"
    warn "$*"
}

log_error() {
    log_raw "ERROR" "$*"
    error "$*"
}

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    log_error "Questa directory non appartiene a una repository Git."
    exit 1
fi

if [[ -z "$(git config user.name)" ]]; then
    log_error "git user.name non configurato"
    exit 1
fi

if [[ -z "$(git config user.email)" ]]; then
    log_error "git user.email non configurato"
    exit 1
fi

repo_name=$(basename "$(git rev-parse --show-toplevel)")
branch=$(git branch --show-current)

if [[ -z "$branch" ]]; then
    branch="(nessun commit)"
fi

user=$(whoami)
host=$(hostnamectl --static)

echo
echo "󰊢 Git Publish"
echo
echo "------------------------------------"
echo "󰉋 Repository : $repo_name"
echo "󰒋 Branch     : $branch"
echo "󰋼 Utente     : $user"
echo "󰞇 Host       : $host"
echo "------------------------------------"

log_raw "INFO" "Repository: $repo_name"
log_raw "INFO" "Branch: $branch"
log_raw "INFO" "Utente: $user"
log_raw "INFO" "Host: $host"

echo
echo "Remote configurati:"

remotes=$(git remote)

if [[ -z "$remotes" ]]; then
    warn "Nessun remote configurato."
    exit 1
fi

while read -r remote; do
    [[ -z "$remote" ]] && continue
    echo "  - $remote"
done <<< "$remotes"

echo
log_info "Analisi modifiche..."

git add -A

if git diff --cached --quiet; then
    log_info "Nessuna modifica rilevata."
    exit 0
fi

log_success "Modifiche rilevate."

echo
echo "File modificati:"
git diff --cached --name-status

echo
read -rp "Descrizione modifica (opzionale): " description

if [[ -n "$description" ]]; then
    log_raw "INFO" "Descrizione: $description"
fi

echo
read -rp "Procedere con commit e push? [Y/n] " confirm

case "$confirm" in
    ""|Y|y)
        ;;
    *)
        log_warn "Operazione annullata."
        exit 0
        ;;
esac

timestamp=$(date '+%Y-%m-%d %H:%M:%S')

commit_title="[SERVER] Edit by $user on $host - $timestamp"

echo
log_info "Creazione commit..."

if [[ -n "$description" ]]; then
    git commit -m "$commit_title" -m "$description"
else
    git commit -m "$commit_title"
fi

if [[ $? -ne 0 ]]; then
    log_error "Errore durante la creazione del commit."
    exit 1
fi

commit_hash=$(git rev-parse --short HEAD)

log_success "Commit creato: $commit_hash"

failed_pushes=0

echo
log_info "Push verso i remote..."

while read -r remote; do

    [[ -z "$remote" ]] && continue

    echo
    info "Push verso $remote..."

    if git push "$remote" "$branch"; then
        log_success "Push completato su $remote"
    else
        log_error "Push fallito su $remote"
        ((failed_pushes++))
    fi

done <<< "$remotes"

echo
echo "------------------------------------"

if (( failed_pushes == 0 )); then
    success "Operazione completata con successo."
    echo "Commit: $commit_hash"
    log_raw "OK" \
    "Operazione completata con successo. Commit: $commit_hash"
    exit 0
else
    error "Operazione completata con errori."
    echo "Commit: $commit_hash"
    echo "Remote falliti: $failed_pushes"
    log_error "Operazione completata con errori. Commit: $commit_hash. Remote falliti: $failed_pushes"
    exit 1
fi
